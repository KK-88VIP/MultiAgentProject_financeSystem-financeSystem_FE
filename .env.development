# ============================================
# 文件名称: .env.development
# 文件版本: V1.0
# 文件用途: 开发环境变量配置
# 创建时间: 2026-04-20
# 最新修改: 2026-04-20
# 修改人: aQian (前端开发)
# 说明: 财务数据分析看板项目 - 开发环境配置
# ============================================

# API 基础地址（开发环境留空，走 Vite /api 代理，避免浏览器 CORS）
VITE_API_BASE_URL=

# 应用标题
VITE_APP_TITLE=财务数据分析看板

# MVP 阶段默认用户 ID
VITE_DEFAULT_USER_ID=user_001

# 与后端 X-User-Role 一致：admin | user
VITE_DEFAULT_USER_ROLE=user

# 看板 DSL：true 走 /api/dashboard/dsl/render，false 走 /kpi + /chart
VITE_USE_DSL_RENDER=false

# DSL 模式下必填，与后端已创建看板 id 对齐（示例见 Python 文档 dash_demo_00001）
VITE_DASHBOARD_ID=
